# =============================================================================
# ea-bot-shop — environment template
# =============================================================================
# Copy to `.env` for local dev (repo root). Never commit real secrets.
#
# Split deploy (typical):
#   • Railway (or similar)  → all non-VITE_* server variables below
#   • Cloudflare Pages    → VITE_* at build time (Settings → Environment)
#
# Vite loads VITE_* from this directory (see vite.config.ts envDir).
# =============================================================================

# --- Required in production (API) ---
NODE_ENV=development
PORT=3000
JWT_SECRET=change-me-min-32-chars-in-production
DATABASE_URL=mysql://user:pass@host:3306/dbname

# Comma-separated browser origins allowed to call the API (no spaces).
# Required when frontend and API are on different hosts (e.g. Pages + Railway).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# After OAuth, user is redirected here (your public site URL, no trailing slash issues handled in code).
FRONTEND_APP_URL=http://localhost:5173

# Behind Railway / reverse proxy (X-Forwarded-*). Default is fine for most hosts.
TRUST_PROXY=1

# Optional: shared cookie domain e.g. .example.com
# COOKIE_DOMAIN=

# --- OAuth / identity (server + must match Pages build for VITE_APP_ID) ---
OAUTH_SERVER_URL=
VITE_APP_ID=
OWNER_OPEN_ID=

# --- Forge / storage proxy & LLM gateway (uploads + ai chat use these keys) ---
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# --- Stripe (checkout + webhook) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (notifications; optional until you enable mail) ---
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# --- S3-style (integration health checks; extend code if you use AWS SDK directly) ---
S3_BUCKET=
S3_ENDPOINT=

# --- Security & ops (optional but recommended in production) ---
CSRF_SECRET=
SENTRY_DSN=
# Falls back to JWT_SECRET for some encrypted config if unset
API_ENCRYPTION_KEY=

# =============================================================================
# Cloudflare Pages — set these in the dashboard for Production / Preview builds
# (same names; do not rely on Railway to inject VITE_* into the static bundle)
# =============================================================================

# Public API base URL, no trailing slash (e.g. https://your-api.up.railway.app)
VITE_API_BASE_URL=http://localhost:3000

# Must match VITE_APP_ID above when using hosted OAuth portal
VITE_OAUTH_PORTAL_URL=

# --- Optional: checkout manual payment copy on Checkout page ---
# VITE_BANK_ACCOUNT_NUMBER=
# VITE_BANK_ACCOUNT_NAME=
# VITE_CRYPTO_BTC_ADDRESS=
# VITE_CRYPTO_USDT_TRC20_ADDRESS=

# --- Optional: Umami analytics (see client/src/main.tsx) ---
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=

# --- Optional: Map / Forge frontend (see client/src/components/Map.tsx) ---
# VITE_FRONTEND_FORGE_API_URL=
# VITE_FRONTEND_FORGE_API_KEY=

# =============================================================================
# ENTERPRISE ADDITIONS
# =============================================================================

# --- Email (transactional queue) ---
SMTP_PORT=587
SMTP_FROM=noreply@neoxp.store

# --- Affiliate ---
# Default commission rate is 10% (configurable per affiliate in DB)

# --- Organization ---
# Multi-tenant support is built-in, no extra env needed

# --- Security ---
# IP blocklist is managed via Admin Panel > Security

# --- Google OAuth ---
# 1. https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Authorized redirect URI: https://your-api.railway.app/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-api.railway.app/api/auth/google/callback

# --- Market Data (Twelve Data) ---
# Free API key: https://twelvedata.com/apikey
# Free tier: 800 requests/day (cached 30s on server)
# Supports: Forex, Crypto, Stocks, Indices (real-time)
TWELVE_DATA_API_KEY=
